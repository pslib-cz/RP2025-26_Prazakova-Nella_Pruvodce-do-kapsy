const roomsData = [];
const roomsGroup = document.getElementById('Mfirst-rooms');
const currentFloorId = 1; // TADY si nastav ID patra, které zrovna exportuješ

if (roomsGroup) {
    roomsGroup.querySelectorAll('rect, path').forEach(room => {
        const id = room.getAttribute('id');
        if (!id) return;

        let svgData = "";
        if (room.tagName.toLowerCase() === 'rect') {
            const x = parseFloat(room.getAttribute('x'));
            const y = parseFloat(room.getAttribute('y'));
            const w = parseFloat(room.getAttribute('width'));
            const h = parseFloat(room.getAttribute('height'));
            svgData = `M${x},${y} h${w} v${h} h-${w} z`;
        } else {
            svgData = room.getAttribute('d');
        }

        const bbox = room.getBBox();
        
        // Generujeme objekt tak, aby přesně seděl na RoomData
        roomsData.push({
            roomId: id,                               // Místo 'id'
            label: id.includes('toilet') ? "WC" : id, // Místo 'name'
            svgData: svgData,                         // Místo 'path'
            coordinateX: Math.round(bbox.x + (bbox.width / 2)),
            coordinateY: Math.round(bbox.y + (bbox.height / 2)),
            type: id.includes('toilet') ? "3" : "0",
            floorId: currentFloorId                   // Tohle ti v JSONu chybělo
        });
    });

    console.log(JSON.stringify(roomsData, null, 2));
}
